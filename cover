<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Cover E-book</title>
    <style>
        body {
            font-family: 'Georgia', serif;
            background-color: #0d233a;
            color: #ffffff;
            margin: 0;
            padding: 40px 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 80vh;
        }
        .border-container {
            border: 3px double #d4af37;
            padding: 40px;
            max-width: 600px;
            margin: 0 auto;
            background-color: rgba(255, 255, 255, 0.03);
        }
        h1 {
            color: #d4af37;
            font-size: 2.2rem;
            letter-spacing: 2px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }
        h2 {
            font-size: 1.8rem;
            font-weight: normal;
            margin-top: 5px;
            color: #ffffff;
        }
        .sub {
            font-size: 1.2rem;
            color: #d4af37;
            margin: 30px 0;
            font-style: italic;
        }
        .badge {
            background-color: #d4af37;
            color: #0d233a;
            padding: 10px 20px;
            font-weight: bold;
            display: inline-block;
            margin: 20px 0;
            border-radius: 4px;
            font-size: 1.1rem;
        }
        .meta {
            margin-top: 5px;
            font-size: 1rem;
            color: #e0e0e0;
            line-height: 1.6;
        }
        .year {
            margin-top: 40px;
            color: #d4af37;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="border-container">
        <h1>Menggali Prinsip Transparansi</h1>
        <p style="color:#d4af37; font-size:1.2rem;">DALAM</p>
        <h2>Dropshipping dan Affiliate Marketing</h2>
        
        <div class="badge">TENTANG LARANGAN BAI’ MĀ LĀ YAMLIK</div>
        
        <p class="sub">◆ Perspektif Hadis dan Fiqih Muamalah Kontemporer ◆</p>
        
        <div class="meta">
            <p><strong>Penulis:</strong> Alif Naufal</p>
            <p><strong>Editor:</strong> Ahmad Aldiansyah</p>
        </div>
        <div class="year">2026</div>
    </div>
</body>
</html>
